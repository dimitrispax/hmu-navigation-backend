  description String?                  @db.VarChar(100)
}

model building {
  id          String                   @id @db.VarChar(10)
  campusId    String?                  @db.VarChar(5)
  description String?                  @db.VarChar(255)
  heightAgl   Float
  geom        Unsupported("geometry")?
  mtrans      mtrans[]

  @@index([geom], map: "sidx_building_geom", type: Gist)
}

model door {
  id          String                   @id(map: "doors_pkey") @db.VarChar
  geom        Unsupported("geometry")?
  description String?                  @db.VarChar(100)
  roomid      String?                  @db.VarChar(30)
  leftopen    Int?
  maindoor    Int?
  openangle   Float?
}

model equipment {
  id       Int     @id
  type     Int
  model    String? @db.VarChar(100)
  serial   String? @db.VarChar(100)
  quantity Int?
}

model equipmentType {
  id          Int    @id
  description String @db.VarChar(100)
}

model mtrans {
  id       String   @db.VarChar(10)
  target   String   @db.VarChar(20)
  r        Float    @default(0)
  sx       Float    @default(1)
  sy       Float    @default(1)
  tx       Float    @default(0)
  ty       Float    @default(0)
  building building @relation(fields: [id], references: [id], onDelete: Cascade, map: "mtrans_fk")

  @@id([id, target], map: "mtrans_pk")
}

model photo {
  id       Int    @id
  roomId   String @db.VarChar(30)
  mimeType String @db.VarChar(100)
  data     Bytes?
}

model post {
  id        Int     @id @default(autoincrement())
  title     String  @db.VarChar(255)
  content   String? @db.VarChar(255)
  published Boolean
  author    Int
  authorid  Int
  userr     userr   @relation(fields: [authorid], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_post")
}

model room {
  id          String                   @id(map: "room3_pkey") @db.VarChar
  geom        Unsupported("geometry")?
  floorId     String?                  @db.VarChar(20)
  description String?                  @db.VarChar(100)
  usageId     Int?
  manager     String?                  @db.VarChar(30)
  computer    Int?
  camera      Int?
  projector   Int?
  capacity    Int?
  geodata     String?
}

model roomUsage {
  roomId  String @db.VarChar(30)
  usageId Int

  @@id([roomId, usageId], map: "roomUsage_pkey1")
}

model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

model usage {
  id          Int    @id(map: "roomUsage_pkey")
  description String @db.VarChar(100)
}

model userr {
  id    Int    @id @default(autoincrement())
  email String @unique @db.VarChar(255)
  name  String @db.VarChar(255)
  post  post[]
}
